# ─────────────────────────────────────────────────────────────────────────────
# ChatToSales — Production Environment Variables
#
# HOW TO USE:
#   1. Copy this file to .env.prod on the server:
#        cp .env.prod.example .env.prod
#   2. Fill in every value marked CHANGE_ME.
#   3. Never commit .env.prod to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=ChatToSales
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
ALLOWED_HOSTS=["https://chattosales.duckdns.org"]

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_USER and POSTGRES_PASSWORD are read by docker-compose.prod.yml
# as well as embedded in DATABASE_URL below.
POSTGRES_USER=chattosales
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql+asyncpg://chattosales:CHANGE_ME_STRONG_PASSWORD@postgres:5432/chattosales

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ── WhatsApp / Meta Cloud API ─────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=CHANGE_ME
WHATSAPP_APP_SECRET=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_ACCESS_TOKEN=CHANGE_ME

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=CHANGE_ME
